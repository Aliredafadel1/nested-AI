# Copy to .env and fill in all values before starting the stack.

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://nestai:nestai@db:5432/nestai
DATABASE_URL_SYNC=postgresql+psycopg2://nestai:nestai@db:5432/nestai
POSTGRES_USER=nestai
POSTGRES_PASSWORD=nestai
POSTGRES_DB=nestai

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── MinIO (object storage) ────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=your_minio_user
MINIO_ROOT_PASSWORD=your_minio_password
MINIO_SECURE=false

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-min-32-chars-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=false

# ── AI providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# ── SMTP (password reset emails) ─────────────────────────────────────────────
# Example with Gmail: use an App Password, not your account password.
# Example with Mailtrap (dev): use the credentials from your Mailtrap inbox.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@nestai.app

# ── Frontend (used to build reset-password links) ────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Misc ─────────────────────────────────────────────────────────────────────
SENTRY_DSN=
ENVIRONMENT=development
BCRYPT_WORK_FACTOR=12
OSRM_URL=http://osrm:5000
