# ─────────────────────────────────────────────────────────────────────────────
# NestAI — Production Environment (Oracle Cloud)
# cp .env.prod.example .env  →  fill every CHANGE_ME  →  ./deploy.sh
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Docker-managed PostgreSQL on the same Oracle instance) ──────────
DATABASE_URL=postgresql+asyncpg://nestai:CHANGE_ME@db:5432/nestai
DATABASE_URL_SYNC=postgresql+psycopg2://nestai:CHANGE_ME@db:5432/nestai
POSTGRES_USER=nestai
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=nestai

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── MinIO ─────────────────────────────────────────────────────────────────────
# MINIO_ENDPOINT must be your Oracle instance PUBLIC IP (not localhost).
# Browsers need to reach this address to load listing photos via presigned URLs.
MINIO_ENDPOINT=YOUR_ORACLE_PUBLIC_IP:9000
MINIO_ROOT_USER=nestai
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_SECURE=false

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_HEX
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=false

# ── AI providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
FRONTEND_URL=http://YOUR_ORACLE_PUBLIC_IP
BCRYPT_WORK_FACTOR=12
OSRM_URL=http://osrm:5000
SENTRY_DSN=

# ── Email (optional — leave blank to disable) ─────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@nestai.app
